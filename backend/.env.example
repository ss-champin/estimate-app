# =============================================================
# .env.example — コピーして .env.local を作成してください
# cp .env.example .env.local
# =============================================================

APP_ENV=local   # local | production

# ── DB ────────────────────────────────────────────────────────
# DB なしで開発: 空のまま（または USE_DATABASE=false）。永続化・利用回数の記録は行われません。
# PostgreSQL を使うとき: 下の例をコピーして URL を設定し USE_DATABASE=auto（既定）に。
# USE_DATABASE=auto
# ローカル（Docker）:
#   DATABASE_URL=postgresql+asyncpg://estimate:estimate_password@localhost:5432/estimate_dev
# 本番（Neon）:
#   DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.neon.tech/estimate?ssl=require
DATABASE_URL=

# ── AI ────────────────────────────────────────────────────────
# local → gemini / production → claude
# 未設定でもサーバーは起動し、見積もりAPIはサンプル値を返します（本番では必須）。
AI_PROVIDER=gemini
GEMINI_API_KEY=                  # https://aistudio.google.com → Get API key（推奨。設定時は GOOGLE_API_KEY にも自動反映）
# GOOGLE_API_KEY=                # 通常は不要。AI Studio キーは GEMINI のみでよい
ANTHROPIC_API_KEY=               # https://console.anthropic.com → API Keys

# ── Clerk 認証（本番・Clerk ありのローカル）────────────────────────
# JWT 公開鍵: https://dashboard.clerk.com → API Keys → 「Show JWT public key」
#  issuer: ダッシュボードの JWT テンプレまたは実際のトークンをデコードし iss を確認（推奨）
#  Webhook: Developers → Webhooks → Endpoint URL に
#    {BACKEND}/api/clerk/webhook を登録。Signing secret を CLERK_WEBHOOK_SECRET に。
CLERK_SECRET_KEY=sk_test_
CLERK_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# CLERK_JWT_ISSUER=https://xxxx.clerk.accounts.dev
# CLERK_WEBHOOK_SECRET=whsec_...
#
# --- ローカル・Clerk なし開発 ---
# APP_ENV=local かつ CLERK_JWT_PUBLIC_KEY が空（または … 入り PEM）のとき、
#   API は Authorization: Bearer local-dev のみ受け付け（フロントの「Clerk なし」モードと一致）
# LOCAL_DEV_AUTH_BYPASS=true  # PEM があっても上記バイパスを強制したいとき

# ── Stripe 決済 ───────────────────────────────────────────────
# STRIPE_WEBHOOK_SECRET が空のとき、Webhook エンドポイントは検証をスキップして 200 を返します。
# https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_ID=price_

# ── アプリ設定 ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000"]
